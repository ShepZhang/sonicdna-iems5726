# Trained sklearn artifacts (*.pkl, *.joblib) ARE tracked here so the
# public source repository can serve the "link to trained model(s)"
# required by IEMS5726 project rules. They are tiny (<400 KB total)
# and reproducible from the Kaggle dataset via pipeline/preprocess.py.
source_code/models/*.npz

